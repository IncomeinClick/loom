# ============================================
# Loom — Environment Configuration
# ============================================
# Copy this to .env and fill in your values.
# The app reads these on startup (no restart = no change).

# --- Auth ---
# Token required in Authorization: Bearer <token> header
# Change this to something secure in production!
API_BEARER_TOKEN=change-me-to-a-secure-random-string

# --- Encryption ---
# Fernet key for encrypting stored credentials (API keys etc.)
# Generate one: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty in dev = credentials stored as plain text
FERNET_KEY=

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///data/loom.db

# --- LLM API Keys (optional, can use Credentials UI instead) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Paths ---
DATA_DIR=data
CONFIGS_DIR=data/configs
ASSETS_DIR=data/assets

# --- Features ---
GIT_AUTO_COMMIT=false
