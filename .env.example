# Loom configuration
# Copy this to .env or run the app — the setup wizard will fill in the auth fields automatically.

# === Authentication (auto-generated by setup wizard) ===
FERNET_KEY=
API_BEARER_TOKEN=
USER_EMAIL=
USER_PASS_HASH=

# === Database ===
# DATABASE_URL=sqlite+aiosqlite:///data/loom.db

# === LLM API keys (optional — needed for LLM step types and asset generation) ===
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# === Facebook App (optional — needed to exchange short-lived for long-lived page tokens) ===
FB_APP_ID=
FB_APP_SECRET=

# === Telegram notifications (optional — leave blank to disable) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# === Nova services (optional — only needed if you use the Nova Voice/Video step executors) ===
NOVA_VOICE_URL=
NOVA_VIDEO_URL=

# === Features ===
# GIT_AUTO_COMMIT=false
