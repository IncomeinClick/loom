# Loom Server Environment
# Copy to /opt/loom/.env and fill in values

# Security — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
API_BEARER_TOKEN=change-this-to-a-strong-token

# Database
DATABASE_URL=sqlite+aiosqlite:///data/loom.db

# LLM API Keys (set the ones you use)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Features
GIT_AUTO_COMMIT=false
